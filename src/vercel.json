{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/coin/(.*)", "dest": "/index.html" },
    { "src": "/user/(.*)", "dest": "/index.html" },
    { "src": "/update/(.*)", "dest": "/index.html" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}